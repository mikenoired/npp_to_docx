{
  "name": "npp_to_docx",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "bun run src/cli/main.ts",
    "start:cli": "bun run src/cli/main.ts",
    "start:web": "bun run src/web/server/main.ts",
    "dev:web": "bun run src/scripts/dev-web.ts",
    "dev:web:server": "bun --hot src/web/server/main.ts",
    "dev:web:ui": "vite",
    "build:web:ui": "vite build",
    "build:web:embed": "bun run src/scripts/embed-web-assets.ts",
    "build:cli:bin": "bun build src/cli/main.ts --compile --target=bun-darwin-arm64 --outfile dist/npp-cli",
    "build:web:bin": "bun run build:web:ui && bun run build:web:embed && bun build src/web/server/main.ts --compile --target=bun-darwin-arm64 --outfile dist/npp-web",
    "build:bins": "bun run build:cli:bin && bun run build:web:bin",
    "package:target": "bun run src/scripts/package-target.ts",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "bunx tsc --noEmit && biome check ."
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx": "^9.5.1",
    "iconv-lite": "^0.6.3",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sax": "^1.4.1",
    "sharp": "^0.34.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^22.13.14",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sax": "^1.2.7",
    "@vitejs/plugin-react": "^5.1.4",
    "bun-types": "^1.3.10",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.8.2",
    "vite": "^7.3.1"
  }
}

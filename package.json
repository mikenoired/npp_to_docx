{
  "name": "npp_to_docx",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "build/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"tsc -p tsconfig.electron.json --watch\" \"vite\" \"wait-on build/electron/main.js http://127.0.0.1:5173 && electron .\"",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "dist": "vite build && tsc -p tsconfig.electron.json && electron-builder",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json && biome check ."
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx": "^9.5.1",
    "iconv-lite": "^0.6.3",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sax": "^1.4.1",
    "sharp": "^0.34.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@tailwindcss/vite": "^4.2.1",
    "@types/electron": "^1.6.10",
    "@types/node": "^22.13.14",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sax": "^1.2.7",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "electron": "^37.4.0",
    "electron-builder": "^26.0.12",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.8.2",
    "vite": "^7.3.1",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "local.npp-to-docx.desktop",
    "productName": "NppToDocx",
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/electron/**/*",
      "build/core/**/*",
      "build/shared/**/*",
      "build/web-client/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/sharp/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  }
}
